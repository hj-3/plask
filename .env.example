# Database
DATABASE_URL=postgresql://user:password@localhost:5432/enrollment

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
QUEUE_NAME=enrollment-queue

# Backend
PORT=3001

# Frontend (build-time for Vite, or runtime via docker-entrypoint.sh)
# Leave empty to use nginx proxy (/api -> backend)
# Set to full URL (e.g. http://backend-svc:3001) for Kubernetes direct access
API_BASE_URL=
VITE_API_BASE_URL=
